# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/
.coverage

# Secrets / local env
.env
*.local.yaml

# Runtime data & state (large or machine-specific) — anchored to repo root
# so source packages like finora/data are not caught
/data/
/logs/
/state/
/reports/
/mlruns/
/.qlib/

# Model artifacts are large; backtest result JSON/CSV under artifacts/backtests IS tracked
artifacts/models/

# OS
.DS_Store

# qlib/mlflow writes a stray lock under a mangled absolute path when training
/Users/
